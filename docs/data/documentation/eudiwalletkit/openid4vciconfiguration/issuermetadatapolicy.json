{"abstract":[{"type":"text","text":"Policy for handling signed issuer metadata fetched from "},{"type":"codeVoice","code":"\/.well-known\/openid-credential-issuer"},{"type":"text","text":"."}],"metadata":{"role":"symbol","roleHeading":"Instance Property","symbolKind":"property","modules":[{"name":"EudiWalletKit"}],"fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"issuerMetadataPolicy"},{"kind":"text","text":": "},{"preciseIdentifier":"s:10OpenID4VCI20IssuerMetadataPolicyO","kind":"typeIdentifier","text":"IssuerMetadataPolicy"}],"externalID":"s:13EudiWalletKit23OpenId4VciConfigurationV20issuerMetadataPolicy0D6ID4VCI06IssueriJ0Ovp","title":"issuerMetadataPolicy"},"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"issuerMetadataPolicy"},{"kind":"text","text":": "},{"preciseIdentifier":"s:10OpenID4VCI20IssuerMetadataPolicyO","kind":"typeIdentifier","text":"IssuerMetadataPolicy"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":".ignoreSigned"},{"type":"text","text":" (default): wallet sends "},{"type":"codeVoice","code":"Accept: application\/json"},{"type":"text","text":" and only accepts plain JSON metadata. Backwards-compatible with all existing deployments."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":".preferSigned(issuerTrust:)"},{"type":"text","text":": wallet sends "},{"type":"codeVoice","code":"Accept: application\/jwt, application\/json"},{"type":"text","text":". If the issuer returns a signed JWT, the signature is verified against the supplied trust anchor; otherwise plain JSON is accepted as a fallback."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice",