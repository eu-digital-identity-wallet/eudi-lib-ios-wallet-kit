{"seeAlsoSections":[{"identifiers":["doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/GetStarted","doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/SecureAreas","doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/PresentationService","doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/WalletUI"],"anchor":"Essentials","title":"Essentials","generated":true}],"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit"]]},"metadata":{"role":"article","modules":[{"name":"EudiWalletKit"}],"roleHeading":"Article","title":"Manage documents"},"sections":[],"identifier":{"url":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/ManageDocuments","interfaceLanguage":"swift"},"kind":"article","abstract":[{"type":"text","text":"The EudiWallet class provides a set of methods to work with documents."}],"variants":[{"paths":["\/documentation\/eudiwalletkit\/managedocuments"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"content":[{"text":"Loading documents","level":3,"anchor":"Loading-documents","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/EudiWallet\/loadDocuments(status:)","isActive":true,"type":"reference"},{"text":" method returns documents with a specific status from storage.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The following example shows how to retrieve issued documents:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":[" public func loadDocuments() async throws {","\t\tlet documents = try await wallet.loadDocuments(status: .issued)","\t}"]},{"type":"paragraph","inlineContent":[{"text":"To load documents of all statuses use the ","type":"text"},{"identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/EudiWallet\/loadAllDocuments()","isActive":true,"type":"reference"},{"text":" method.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["let documents = try await wallet.loadAllDocuments()"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/EudiWallet\/loadDocument(id:status:)","type":"reference"},{"type":"text","text":" method returns a document with a given id and status."}]},{"type":"paragraph","inlineContent":[{"text":"The following example shows how to retrieve a document:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["let document = try await wallet.loadDocument(id: documentId, status: .issued)"]},{"text":"Storage manager","level":3,"anchor":"Storage-manager","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The read-only property "},{"code":"storage","type":"codeVoice"},{"type":"text","text":" is an instance of a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/StorageManager"},{"type":"text","text":" class."},{"type":"text","text":" "},{"type":"text","text":"Currently the keychain implementation is used. It provides document management functionality using the iOS KeyChain."}]},{"type":"paragraph","inlineContent":[{"text":"The storage model provides the following models for the supported well-known document types:","type":"text"}]},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"DocType"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Model"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"eu.europa.ec.eudiw.pid.1"}],"type":"paragraph"}],[{"inlineContent":[{"identifier":"https:\/\/eu-digital-identity-wallet.github.io\/eudi-lib-ios-iso18013-data-model\/documentation\/mdocdatamodel18013\/eupidmodel","type":"reference","isActive":true}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"org.iso.18013.5.1.mDL","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"identifier":"https:\/\/eu-digital-identity-wallet.github.io\/eudi-lib-ios-iso18013-data-model\/documentation\/mdocdatamodel18013\/isomdlmodel","isActive":true,"type":"reference"}],"type":"paragraph"}]]]},{"inlineContent":[{"type":"text","text":"Since the issued mDoc documents retrieved expose only basic metadata and the raw data, they must be decoded to the corresponding CBOR models. The library provides the "},{"code":"StorageManager\/toClaimsModel(doc:modelFactory:)","type":"codeVoice"},{"type":"text","text":" function to decode document raw CBOR data to strongly-typed models conforming to "},{"type":"reference","isActive":true,"identifier":"https:\/\/eu-digital-identity-wallet.github.io\/eudi-lib-ios-iso18013-data-model\/documentation\/mdocdatamodel18013\/DocClaimsDecodable"},{"type":"text","text":" protocol."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The loading functions automatically update the "},{"identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/StorageManager","type":"reference","isActive":true},{"type":"text","text":" members. The decoded issued documents are available in the "},{"identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/StorageManager\/docModels","type":"reference","isActive":true},{"type":"text","text":" property. The deferred and pending documents are available in the "},{"identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/StorageManager\/deferredDocuments","type":"reference","isActive":true},{"type":"text","text":" and "},{"identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/StorageManager\/pendingDocuments","type":"reference","isActive":true},{"type":"text","text":" properties respectively."}],"type":"paragraph"},{"inlineContent":[{"text":"For other document types the ","type":"text"},{"identifier":"https:\/\/eu-digital-identity-wallet.github.io\/eudi-lib-ios-iso18013-data-model\/documentation\/mdocdatamodel18013\/genericmdocmodel","isActive":true,"type":"reference"},{"text":" is provided.","type":"text"}],"type":"paragraph"},{"level":3,"text":"Deleting a document","type":"heading","anchor":"Deleting-a-document"},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/EudiWallet\/deleteDocument(id:status:)"},{"type":"text","text":" method that deletes a document with the given id."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example shows how to delete a document:"}]},{"type":"codeListing","code":["try await wallet.deleteDocument(id: documentId, status: .issued)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To delete all documents you can use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/EudiWallet\/deleteAllDocuments()"}]},{"anchor":"Credential-Reuse-Policy-Mapping","type":"heading","text":"Credential Reuse Policy Mapping","level":3},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"When ETSI TS 119 472-3 Once-Only reuse method is applied, the oneTimeUse credential policy is used."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When ETSI TS 119 472-3 Limited-time reuse method is applied, the rotateUse credential policy is used and the batch size is set to 1."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"When ETSI TS 119 472-3 Rotating-Batch reuse method is applied, the rotateUse credential policy is used."}],"type":"paragraph"}]}]},{"anchor":"Refreshing-usage-counters","type":"heading","text":"Refreshing usage counters","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/EudiWallet\/refreshUsageCounters()","isActive":true},{"type":"text","text":" method synchronizes the wallet’s cached usage counter values with the actual state on the device."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Usage counters track how many times a document can be presented (for one-time use policies). When a presentation occurs in another application (such as DC-API extension) that shares access to the secure area, the wallet’s cached counters may become out of sync. This method refreshes those cached values so that the wallet displays accurate remaining presentation counts."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When a counter value changes, the corresponding document model publishes the change, allowing SwiftUI views to automatically update."}]},{"type":"paragraph","inlineContent":[{"text":"The recommended approach is to refresh usage counters when your app returns to the foreground, ensuring that any presentations that occurred in other apps are reflected in the wallet:","type":"text"}]},{"type":"codeListing","code":[".onReceive(NotificationCenter.default.publisher(for: UIApplication.willEnterForegroundNotification)) { _ in","    Task { try? await wallet.refreshUsageCounters() }","}"],"syntax":"swift"}],"kind":"content"}],"references":{"doc://EudiWalletKit/documentation/EudiWalletKit/EudiWallet/refreshUsageCounters()":{"identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/EudiWallet\/refreshUsageCounters()","url":"\/documentation\/eudiwalletkit\/eudiwallet\/refreshusagecounters()","type":"topic","role":"symbol","title":"refreshUsageCounters()","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"refreshUsageCounters"},{"kind":"text","text":"() "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"}],"kind":"symbol","abstract":[{"type":"text","text":"Refresh usage counters for all loaded issued documents."}]},"doc://EudiWalletKit/documentation/EudiWalletKit/WalletUI":{"role":"sampleCode","title":"EUDI iOS Wallet reference implementation","