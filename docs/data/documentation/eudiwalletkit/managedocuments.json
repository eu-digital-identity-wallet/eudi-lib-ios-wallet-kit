{"sections":[],"kind":"article","abstract":[{"type":"text","text":"The EudiWallet class provides a set of methods to work with documents."}],"variants":[{"paths":["\/documentation\/eudiwalletkit\/managedocuments"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"modules":[{"name":"EudiWalletKit"}],"title":"Manage documents","roleHeading":"Article","role":"article"},"seeAlsoSections":[{"generated":true,"anchor":"Essentials","identifiers":["doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/GetStarted","doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/SecureAreas","doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/PresentationService","doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/WalletUI"],"title":"Essentials"}],"hierarchy":{"paths":[["doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit"]]},"primaryContentSections":[{"kind":"content","content":[{"text":"Loading documents","type":"heading","anchor":"Loading-documents","level":3},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/EudiWallet\/loadDocuments(status:)","isActive":true,"type":"reference"},{"text":" method returns documents with a specific status from storage.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The following example shows how to retrieve issued documents:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":[" public func loadDocuments() async throws {","\t\tlet documents = try await wallet.loadDocuments(status: .issued)","\t}"]},{"inlineContent":[{"text":"To load documents of all statuses use the ","type":"text"},{"identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/EudiWallet\/loadAllDocuments()","isActive":true,"type":"reference"},{"text":" method.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let documents = try await wallet.loadAllDocuments()"]},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/EudiWallet\/loadDocument(id:status:)","isActive":true,"type":"reference"},{"text":" method returns a document with a given id and status.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The following example shows how to retrieve a document:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let document = try await wallet.loadDocument(id: documentId, status: .issued)"]},{"text":"Storage manager","type":"heading","anchor":"Storage-manager","level":3},{"inlineContent":[{"text":"The read-only property ","type":"text"},{"code":"storage","type":"codeVoice"},{"text":" is an instance of a ","type":"text"},{"identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/StorageManager","isActive":true,"type":"reference"},{"text":" class.","type":"text"},{"text":" ","type":"text"},{"text":"Currently the keychain implementation is used. It provides document management functionality using the iOS KeyChain.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The storage model provides the following models for the supported well-known document types:","type":"text"}],"type":"paragraph"},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"DocType"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Model"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"eu.europa.ec.eudiw.pid.1"}],"type":"paragraph"}],[{"inlineContent":[{"identifier":"https:\/\/eu-digital-identity-wallet.github.io\/eudi-lib-ios-iso18013-data-model\/documentation\/mdocdatamodel18013\/eupidmodel","type":"reference","isActive":true}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"org.iso.18013.5.1.mDL"}],"type":"paragraph"}],[{"inlineContent":[{"identifier":"https:\/\/eu-digital-identity-wallet.github.io\/eudi-lib-ios-iso18013-data-model\/documentation\/mdocdatamodel18013\/isomdlmodel","type":"reference","isActive":true}],"type":"paragraph"}]]]},{"inlineContent":[{"text":"Since the issued mDoc documents retrieved expose only basic metadata and the raw data, they must be decoded to the corresponding CBOR models. The library provides the ","type":"text"},{"code":"StorageManager\/toClaimsModel(doc:modelFactory:)","type":"codeVoice"},{"text":" function to decode document raw CBOR data to strongly-typed models conforming to ","type":"text"},{"identifier":"https:\/\/eu-digital-identity-wallet.github.io\/eudi-lib-ios-iso18013-data-model\/documentation\/mdocdatamodel18013\/DocClaimsDecodable","isActive":true,"type":"reference"},{"text":" protocol.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The loading functions automatically update the ","type":"text"},{"identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/StorageManager","isActive":true,"type":"reference"},{"text":" members. The decoded issued documents are available in the ","type":"text"},{"identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/StorageManager\/docModels","isActive":true,"type":"reference"},{"text":" property. The deferred and pending documents are available in the ","type":"text"},{"identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/StorageManager\/deferredDocuments","isActive":true,"type":"reference"},{"text":" and ","type":"text"},{"identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/StorageManager\/pendingDocuments","isActive":true,"type":"reference"},{"text":" properties respectively.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For other document types the ","type":"text"},{"identifier":"https:\/\/eu-digital-identity-wallet.github.io\/eudi-lib-ios-iso18013-data-model\/documentation\/mdocdatamodel18013\/genericmdocmodel","isActive":true,"type":"reference"},{"text":" is provided.","type":"text"}],"type":"paragraph"},{"text":"Deleting a document","type":"heading","anchor":"Deleting-a-document","level":3},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/EudiWallet\/deleteDocument(id:status:)","isActive":true,"type":"reference"},{"text":" method that deletes a document with the given id.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The following example shows how to delete a document:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["try await wallet.deleteDocument(id: documentId, status: .issued)"]},{"inlineContent":[{"text":"To delete all documents you can use ","type":"text"},{"identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/EudiWallet\/deleteAllDocuments()","isActive":true,"type":"reference"}],"type":"paragraph"},{"text":"Refreshing usage counters","type":"heading","anchor":"Refreshing-usage-counters","level":3},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/EudiWallet\/refreshUsageCounters()","isActive":true,"type":"reference"},{"text":" method synchronizes the wallet’s cached usage counter values with the actual state on the device.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Usage counters track how many times a document can be presented (for one-time use policies). When a presentation occurs in another application (such as DC-API extension) that shares access to the secure area, the wallet’s cached counters may become out of sync. This method refreshes those cached values so that the wallet displays accurate remaining presentation counts.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"When a counter value changes, the corresponding document model publishes the change, allowing SwiftUI views to automatically update.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The recommended approach is to refresh usage counters when your app returns to the foreground, ensuring that any presentations that occurred in other apps are reflected in the wallet:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":[".onReceive(NotificationCenter.default.publisher(for: UIApplication.willEnterForegroundNotification)) { _ in","    Task { try? await wallet.refreshUsageCounters() }","}"]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/ManageDocuments"},"references":{"doc://EudiWalletKit/documentation/EudiWalletKit/GetStarted":{"role":"article","abstract":[{"type":"text","text":"How to install and initialize EUDI Wallet Kit in your project"}],"type":"topic","kind":"article","identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/GetStarted","title":"Get started","url":"\/documentation\/eudiwalletkit\/getstarted"},"https://eu-digital-identity-wallet.github.io/eudi-lib-ios-iso18013-data-model/documentation/mdocdatamodel18013/eupidmodel":{"titleInlineContent":[{"type":"text","text":"EuPidModel"}],"type":"link","url":"https:\/\/eu-digital-identity-wallet.github.io\/eudi-lib-ios-iso18013-data-model\/documentation\/mdocdatamodel18013\/eupidmodel","identifier":"https:\/\/eu-digital-identity-wallet.github.io\/eudi-lib-ios-iso18013-data-model\/documentation\/mdocdatamodel18013\/eupidmodel","title":"EuPidModel"},"doc://EudiWalletKit/documentation/EudiWalletKit/EudiWallet/loadDocuments(status:)":{"role":"symbol","abstract":[{"type":"text","text":"Load documents with a specific status from storage"}],"kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"loadDocuments"},{"kind":"text","text":"("},{"kind":"externalParam","text":"status"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:13WalletStorage14DocumentStatusO","text":"DocumentStatus"},{"kind":"text","text":") "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"te