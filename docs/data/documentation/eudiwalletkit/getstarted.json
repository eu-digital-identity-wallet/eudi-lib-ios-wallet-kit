nnect.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"code":".client","type":"codeVoice"}],"type":"strong"},{"type":"text","text":": The holder device acts as a GATT central (client), scanning and connecting to the reader’s peripheral."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"code":".both","type":"codeVoice"}],"type":"strong"},{"text":": The holder device supports both modes simultaneously and advertises both in the QR device engagement.","type":"text"}],"type":"paragraph"}]}]},{"type":"codeListing","syntax":"swift","code":["let config = EudiWalletConfiguration(","    serviceName: \"my_wallet_app\",","    trustedReaderCertificates: [Data(name: \"eudi_pid_issuer_ut\", ext: \"der\")!],","    bleTransferMode: .server  \/\/ default; use .client or .both as needed",")","let wallet = try! EudiWallet(eudiWalletConfig: config)","wallet.bleTransferMode = .client"]},{"type":"heading","text":"Reader Certificate Revocation Policy","anchor":"Reader-Certificate-Revocation-Policy","level":3},{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/EudiWalletKit\/documentation\/EudiWalletKit\/EudiWalletConfiguration\/crlRevocationPolicy","type":"reference"},{"text":" to control how CRL revocation checks are enforced when validating reader certificates in BLE and OpenID4VP presentation flows.","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":".hardFail"}]},{"text":" (default): if revocation status cannot be confirmed (for example due to missing or unreachable CRL), validation fails.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"code":".softFail","type":"codeVoice"}]},{"type":"text","text":": certificate validation continues when revocation status cannot be determined, but still fails when a certificate is explicitly revoked."}],"type":"paragraph"}]}]},{"code":["let config = EudiWalletConfiguration(","    trustedReaderRootCertificates: [Data(name: \"eudi_pid_issuer_ut\", ext: \"der\")!],","    crlRevocationPolicy: .hardFail",")","let wallet = try! EudiWallet(eudiWalletConfig: config)"],"type":"codeListing","syntax":"swift"},{"level":3,"type":"heading","anchor":"OpenID4VCI-Configuration","text":"OpenID4VCI Configuration"},{"inlineContent":[{"type":"text","text":"The wallet now supports multiple OpenID4VCI issuer configurations for enhanced flexibility. You can configure the wallet with a dictionary of issuer configurations:"}],"type":"paragraph"},{"code":["\/\/ Configure multiple OpenID4VCI issuers with DPoP support","let issuerConfigurations: [String: OpenId4VciConfiguration] = [","    \"eudi_pid_issuer\": OpenId4VciConfiguration(","        credentialIssuerURL: \"https:\/\/pid.issuer.example.com\",","        requireDpop: true,","        issuerMetadataPolicy: .requireSigned,","        dpopKeyOptions: KeyOptions(","            secureAreaName: \"SecureEnclave\", curve: .P256, accessControl: .requireUserPresence","        )","    ),","    \"mdl_issuer\": OpenId4VciConfiguration(","        credentialIssuerURL: \"https:\/\/mdl.issuer.example.com\",","        requireDpop: false,","        issuerMetadataPolicy: .ignoreSigned","    )","]","","\/\/ Register additional issuers after initialization","try wallet.registerOpenId4VciServices(issuerConfigurations)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"Use ","type":"text"},{"code":"issuerMetadataPolicy","type":"codeVoice"},{"text":" to control signed metadata handling per issuer:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":".requireSigned","type":"codeVoice"},{"text":" for issuers that require signed metadata validation","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".ignoreSigned"}